{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "LeMay Commerce",
  "colors": {
    "primary": "#1B3A5C",
    "light": "#3B82F6",
    "dark": "#0F2440"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "architecture"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/overview",
              "tools/orders",
              "tools/customers",
              "tools/products",
              "tools/inventory",
              "tools/fulfillment",
              "tools/analytics",
              "tools/marketing",
              "tools/discounts",
              "tools/content"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/settings",
              "configuration/permissions",
              "configuration/billing"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/pricing",
              "resources/security",
              "resources/support",
              "resources/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "MCP Protocol",
            "pages": [
              "api-reference/mcp/overview",
              "api-reference/mcp/tools",
              "api-reference/mcp/intents"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Commerce App",
          "href": "https://commerce.lemay.app",
          "icon": "store"
        },
        {
          "anchor": "LeMay",
          "href": "https://lemay.app",
          "icon": "building-columns"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@lemay.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://commerce.lemay.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/lemaboratory",
      "github": "https://github.com/lemayinc",
      "linkedin": "https://linkedin.com/company/lemay"
    }
  },
  "seo": {
    "indexHiddenPages": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  }
}
